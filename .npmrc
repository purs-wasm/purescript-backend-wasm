ignore-scripts=true
min-release-age=7

# binaryen is a dependency of the @purs-wasm/binaryen FFI package, but the
# compiled spago output lives at <root>/output and resolves "binaryen" via the
# root node_modules. Hoist it there so the output can import it.
public-hoist-pattern[]=binaryen

# cbor is a dependency of @purs-wasm/compiler; the compiled Node.Cbor output at
# <root>/output resolves "cbor" via the root node_modules, so hoist it there.
public-hoist-pattern[]=cbor