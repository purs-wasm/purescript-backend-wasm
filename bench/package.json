{
  "name": "bench",
  "type": "module",
  "scripts": {
    "build:ps": "cd .. && spago build -p bench --output bench/output",
    "build:wasm": "cd .. && node ./purs-wasm/index.dev.js build -I ./bench/output -O ./bench/output-wasm -e Bench.Main",
    "build:wasm:base": "cd .. && node ./purs-wasm/index.dev.js build -I ./bench/output -O ./bench/output-wasm -e Bench.Main",
    "build": "npm run build:ps && npm run build:wasm",
    "base": "npm run build:ps && npm run build:wasm:base && node run.mjs",
    "snapshot": "./snapshot.sh",
    "graph": "./graph.sh",
    "graph:count-state": "./count-state-graph.sh",
    "graph:curry": "./curry-graph.sh"
  }
}