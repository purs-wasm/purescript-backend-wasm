{
  "name": "bench",
  "type": "module",
  "scripts": {
    "build:ps": "cd .. && spago build -p bench --output bench/output",
    "build:wasm:main": "cd .. && node ./purs-wasm/index.js build -I ./bench/output -O ./bench/output-wasm -e Bench.Main --force",
    "build:wasm:count-effect": "cd .. && node ./purs-wasm/index.js build -I ./bench/output -O ./bench/output-wasm-count-effect -e CountEffect --force",
    "build:wasm:curry": "cd .. && node ./purs-wasm/index.js build -I ./bench/output -O ./bench/output-wasm-curry -e BenchCurry --force",
    "build:wasm": "npm run build:wasm:main && npm run build:wasm:count-effect && npm run build:wasm:curry",
    "build:wasm:base": "npm run build:wasm",
    "build": "npm run build:ps && npm run build:wasm",
    "base": "npm run build:ps && npm run build:wasm:base && node run.mjs",
    "snapshot": "./snapshot.sh",
    "graph": "./graph.sh",
    "graph:count-state": "./count-state-graph.sh",
    "graph:curry": "./curry-graph.sh",
    "graph:count-run": "./count-run-graph.sh"
  }
}
